using Microsoft.EntityFrameworkCore;
using Orbital.API.Data;
using Orbital.API.Models;

namespace Orbital.API.Repositories
{
    public class TipoAtmosferaRepository : ITipoAtmosferaRepository
    {
        private readonly AppDbContext _context;

        public TipoAtmosferaRepository(AppDbContext context)
        {
            _context = context;
        }

        public async Task<IEnumerable<TipoAtmosfera>> ObtenerTodas()
        {
            return await _context.TiposAtmosfera.Where(t => t.Activo).ToListAsync();
        }
    }
}
